// ============================================================
// RepLog — Prisma Schema
// These model names match your exact Supabase table names.
// If you rename a table in Supabase, update the @@map() line
// below — NOT the model name (the model name is what your
// TypeScript code uses).
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pooled connection (for queries)
  directUrl = env("DIRECT_URL")     // direct connection (for migrations)
}

// ── NEXTAUTH MODELS ──────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── USERS ────────────────────────────────────────────────────
// One user can have many workout sessions.
model User {
  id                String    @id @default(cuid())
  name              String?
  email             String?   @unique
  emailVerified     DateTime? @map("email_verified")
  image             String?
  isProfileComplete Boolean   @default(false)
  createdAt         DateTime  @default(now())

  accounts          Account[]
  sessions          Session[]
  sessionsDb        WorkoutSession[] // To avoid naming conflict with NextAuth 'Session'
  exercises         Exercise[]       // the exercises this user created
  notes             Note[]           // personal saved notes

  @@map("users")
}

// ── EXERCISES ────────────────────────────────────────────────
// A library of movements. Seeded once, never changes often.
model Exercise {
  id              String       @id @default(cuid())
  name            String
  primaryMuscle   String
  secondaryMuscle String?      // nullable — isolation lifts may not have one
  mechanics       String       // "Compound" or "Isolation"
  userId          String?      // Which user created it (if personal custom)
  bodyRegion      String?      // Optional classification: "upper" or "lower"
  user            User?        @relation(fields: [userId], references: [id])

  logs            WorkoutLog[]

  @@index([primaryMuscle])
  @@unique([name, userId])
  @@map("exercises")
}

// ── WORKOUT SESSIONS ─────────────────────────────────────────
// One session = one gym visit. Belongs to a user.
model WorkoutSession {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  startTime DateTime     @default(now())
  endTime   DateTime?    // null while session is still active
  isActive  Boolean      @default(true)

  logs      WorkoutLog[]

  @@index([userId, startTime]) // Faster dashboard time-filtering
  @@index([isActive])
  @@map("workout_sessions")
}

// ── WORKOUT LOGS ─────────────────────────────────────────────
// A "slot" for one exercise inside a session.
// e.g. "Barbell Squat" inside "Monday Push".
model WorkoutLog {
  id         String         @id @default(cuid())
  sessionId  String
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])
  orderIndex Int            @default(0) // display order within the session

  sets       SetLog[]

  @@index([sessionId])
  @@index([sessionId, exerciseId])
  @@map("workout_logs")
}

// ── SET LOGS ─────────────────────────────────────────────────
// One logged set: weight, reps, effort, completion.
// This is the core data row for every rep you ever do.
model SetLog {
  id           String     @id @default(cuid())
  workoutLogId String
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  setNumber    Int
  weight       Decimal    @db.Decimal(6, 2) // e.g. 102.50 kg
  reps         Int
  rpe          Float?      // Rate of Perceived Exertion: 1–10 (supports decimals)
  rir          Int?        // Reps in Reserve: 0–10
  isCompleted  Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([workoutLogId])
  @@index([isCompleted, createdAt]) // Massive speed boost for dashboard aggregations
  @@map("set_logs")
}

// ── NOTES ────────────────────────────────────────────────────
// Personal notes attached to a user. Saved permanently.
// Use cases: workout reminders, form cues, PR goals, etc.
model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("")
  content   String   @db.Text
  isPinned  Boolean  @default(false)
  color     String   @default("default") // "default", "lime", "blue", "orange", "pink"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
  @@index([isPinned])
  @@map("notes")
}
