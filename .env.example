# .env.example
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it contains secrets.

################################################################
#  ⚠️  SAFETY ALERT — PLEASE READ  ⚠️
################################################################
# 1. DATABASE_URL: Do NOT use your production Supabase URL 
#    while following tutorials or running "db reset" commands.
#    Use a local Docker DB for experiments.
# 2. LOCAL DEV: Use 'postgresql://postgres:postgres@localhost:54322/postgres'
#    when running the Supabase CLI locally with 'supabase start'.
################################################################

# ── Supabase ──────────────────────────────────────────────────
# Found at: supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Prisma / PostgreSQL ───────────────────────────────────────
# Found at: supabase.com → Settings → Database → Connection string
# Use "Transaction" pooler URL for DATABASE_URL (handles serverless)
# Use "Direct connection" URL for DIRECT_URL (used by migrations)
DATABASE_URL=postgresql://postgres.YOUR_ID:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.YOUR_ID:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── Demo user ─────────────────────────────────────────────────
# Create a row in your "users" table manually (via Prisma Studio
# or the Supabase dashboard), then paste the generated ID here.
DEMO_USER_ID=your-user-cuid-here
